#!/usr/bin/env expect

set timeout 30
set smoke_dir "/tmp/stack-tui-smoke"
set stty_init "rows 45 columns 160"

file delete -force $smoke_dir
file mkdir $smoke_dir

set seed_path "$smoke_dir/seed-session.json"
set handle [open $seed_path w]
puts $handle {
{
  "id": "seed-session-0000-0000-0000-000000000000",
  "workspaceRoot": "/tmp/stack-tui-smoke",
  "startedAt": "2026-06-20T00:00:00.000Z",
  "codexCommand": "codex exec --json --color never -m gpt-5.4-mini -c model_reasoning_effort=\"medium\"",
  "turns": [
    {
      "id": "seed-turn",
      "prompt": "seed prompt",
      "selectedPaths": [],
      "startedAt": "2026-06-20T00:00:00.000Z",
      "finishedAt": "2026-06-20T00:00:01.000Z",
      "exitCode": 0,
      "stdout": "{\"type\":\"item.completed\",\"item\":{\"id\":\"item_0\",\"type\":\"agent_message\",\"text\":\"seed answer\"}}\n{\"type\":\"turn.completed\",\"usage\":{\"input_tokens\":1,\"cached_input_tokens\":0,\"output_tokens\":2,\"reasoning_output_tokens\":0}}\n",
      "stderr": ""
    }
  ]
}
}
close $handle

set output_log "$smoke_dir/output.log"
log_file $output_log

set env(STACK_CODEX_COMMAND) "bun"
set env(STACK_CODEX_ARGS) "run scripts/fake_codex_jsonl.ts"
set env(STACK_SESSION_DIR) $smoke_dir

spawn ./bin/stack
expect "Ask local Codex"
expect "seed prompt"
send -- "hello from expect\r"
expect "Codex is running"
expect "command_execution exit=0"
expect "stack-tool-output"
expect "Not much. I'm here and ready to help with the local workspace."
expect "input:"
expect "reasoning:"
send -- "\t"
send -- "\r"
expect "model gpt-5.5"
send -- "\t"
send -- "\r"
expect "effort low"
send -- "\t"
send -- "\t"
send -- "\t"
send -- "j"
expect "seed-session-0000-0000-0000-000000000000"
send -- "\033"
expect eof

set handle [open $output_log r]
set output [read $handle]
close $handle

set forbidden_events [list "{\"type\":\"thread.started\"" "{\"type\":\"turn.started\"" "{\"type\":\"item.completed\"" "{\"type\":\"turn.completed\"" {[usage]}]
foreach forbidden $forbidden_events {
  if {[string first $forbidden $output] >= 0} {
    puts stderr "terminal leaked raw Codex JSONL event: $forbidden"
    exit 1
  }
}

puts "stack_tui_submit_smoke_ok"
