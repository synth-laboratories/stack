#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

if [[ $# -eq 0 ]] || [[ "${1:-}" == "-h" ]] || [[ "${1:-}" == "--help" ]]; then
  exec "${ROOT}/scripts/stackeval/pipeline.sh" --help
fi

case "${1:-}" in
  run)
    shift
    exec "${ROOT}/scripts/stackeval/pipeline.sh" run "$@"
    ;;
  prepare)
    shift
    exec "${ROOT}/scripts/stackeval/pipeline.sh" run "$@" --prepare-only
    ;;
  *)
    exec "${ROOT}/scripts/stackeval/pipeline.sh" run "$@"
    ;;
esac
