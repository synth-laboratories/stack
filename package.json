{
  "name": "@synth-laboratories/stack",
  "version": "0.2.0-dev.20260629.1",
  "description": "Synth operator cockpit — OpenTUI, Codex agent pane, and Stack MCP for local and hosted research ops.",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/synth-laboratories/stack.git"
  },
  "bugs": {
    "url": "https://github.com/synth-laboratories/stack/issues"
  },
  "homepage": "https://github.com/synth-laboratories/stack#readme",
  "bin": {
    "stack": "./bin/stack",
    "stack-mcp": "./bin/stack-mcp"
  },
  "scripts": {
    "start": "bun run src/main.ts",
    "check": "tsc --noEmit && cargo build -p stackd",
    "smoke:tui": "expect scripts/smoke_tui_submit.expect",
    "smoke:tui:scroll": "expect scripts/smoke_tui_scroll.expect",
    "smoke:tui:focus": "expect scripts/smoke_tui_focus.expect",
    "smoke:tui:crash-cleanup": "expect scripts/smoke_tui_crash_cleanup.expect",
    "smoke:tui:gepa": "bun run scripts/smoke_tui_gepa.ts",
    "smoke:tui:gepa:live": "bun run scripts/smoke_tui_gepa_live.ts",
    "smoke:tui:resilience": "expect scripts/smoke_tui_resilience.expect",
    "smoke:tui:all": "bun run check && expect scripts/smoke_tui_submit.expect && expect scripts/smoke_tui_scroll.expect && bun run scripts/smoke_tui_gepa.ts && expect scripts/smoke_tui_resilience.expect",
    "smoke:transcript": "bun run scripts/smoke_transcript.ts",
    "smoke:agent-context": "bun run scripts/smoke_agent_context.ts",
    "smoke:rate-limits": "bun run scripts/smoke_rate_limits.ts",
    "smoke:usage-cost": "bun run scripts/smoke_usage_cost.ts",
    "smoke:openai-pricing": "bun run scripts/smoke_openai_pricing.ts",
    "smoke:throughput": "bun run scripts/smoke_throughput.ts",
    "smoke:stackd": "bun run scripts/smoke_local_api.ts",
    "smoke:bombadil:tui-scroll": "bun run scripts/smoke_bombadil_tui_scroll.ts",
    "smoke:bombadil:tui-b0": "bun run scripts/smoke_bombadil_tui_b0.ts",
    "smoke:bombadil:b0": "bun run scripts/smoke_bombadil_b0.ts",
    "smoke:install-skills": "bun run scripts/smoke_install_skills.ts",
    "smoke:bootstrap": "bun run scripts/smoke_bootstrap.ts",
    "smoke:version": "bun run scripts/smoke_version.ts",
    "smoke:observability": "bun run scripts/smoke_observability.ts",
    "smoke:observability:retention": "bun run scripts/smoke_observability_retention.ts",
    "smoke:agent-bridge": "bun run scripts/smoke_agent_bridge_codex.ts",
    "smoke:voice:gardener-demo": "bun run scripts/smoke_voice_gardener_demo.ts",
    "smoke:voice:tui": "bun run scripts/smoke_voice_tui.ts",
    "smoke:gardener:v1": "bun run scripts/smoke_gardener_v1.ts",
    "smoke:guidance:l2": "bun run scripts/smoke_guidance_l2.ts",
    "smoke:monitor:style-steer": "bun run scripts/smoke_monitor_style_steer.ts",
    "smoke:mcp:local-threads": "bun run scripts/smoke_mcp_local_threads.ts",
    "smoke:acceptance:t0": "bun run smoke:voice:tui && bun run smoke:gardener:v1 && bun run smoke:guidance:l2 && bun run smoke:mcp:local-threads && bun run smoke:bombadil:b0",
    "release-check": "bun run scripts/release_check.ts",
    "release-check:observability": "STACK_RELEASE_CHECK_OBSERVABILITY=1 bun run scripts/release_check.ts",
    "observability:apply-retention": "bun run scripts/apply_observability_retention.ts",
    "release:guard:b0": "bun run smoke:bombadil:b0",
    "stackeval:banking77-local-gepa": "bun run scripts/stackeval_banking77_local_gepa.ts",
    "stackeval:banking77-local-gepa:prepare": "bun run scripts/stackeval_banking77_local_gepa.ts --prepare-only",
    "stackeval:run": "./bin/stackeval run banking77-local-gepa",
    "stackeval:run:prepare": "./bin/stackeval prepare banking77-local-gepa",
    "stackeval:harness": "./bin/stackeval harness prepare banking77-local-gepa --preset smoke",
    "sync-version": "bun run scripts/sync_version.ts",
    "bump-dev": "bun run scripts/bump_dev.ts"
  },
  "dependencies": {
    "@opentui/core": "^0.4.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.6",
    "typescript": "^6.0.3"
  }
}
