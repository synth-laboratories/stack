{
  "name": "@synth-laboratories/stack",
  "version": "0.2.0-dev.20260701.1",
  "description": "Synth operator cockpit — OpenTUI, Codex agent pane, and Stack MCP for local and hosted research ops.",
  "license": "MIT",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/synth-laboratories/stack.git"
  },
  "bugs": {
    "url": "https://github.com/synth-laboratories/stack/issues"
  },
  "homepage": "https://github.com/synth-laboratories/stack#readme",
  "bin": {
    "stack": "./bin/stack",
    "stack-mcp": "./bin/stack-mcp"
  },
  "scripts": {
    "start": "bun run src/main.ts",
    "check": "tsc --noEmit && cargo build -p stackd",
    "smoke:stackd:telemetry": "STACK_REPO_ROOT=\"$PWD\" bun run ../testing/stack/smoke/smoke_stackd_telemetry.ts",
    "smoke:stackd:crash-report": "STACK_REPO_ROOT=\"$PWD\" bun run ../testing/stack/smoke/smoke_stackd_crash_report.ts",
    "smoke:crash-ingestion": "STACK_REPO_ROOT=\"$PWD\" bun run ../testing/stack/smoke/smoke_stack_crash_ingestion.ts",
    "smoke:telemetry:contract": "STACK_REPO_ROOT=\"$PWD\" bun run ../testing/stack/smoke/smoke_telemetry_contract.ts",
    "smoke:growth-ingestion": "STACK_REPO_ROOT=\"$PWD\" bun run ../testing/stack/smoke/smoke_growth_ingestion.ts",
    "smoke:release-artifact:local": "bun run scripts/package_release_artifact.ts",
    "smoke:bombadil:b0": "STACK_REPO_ROOT=\"$PWD\" sh -c 'cd ../testing && make stack-bombadil-b0'",
    "smoke:installer:contract": "STACK_REPO_ROOT=\"$PWD\" bun run ../testing/stack/smoke/smoke_installer_contract.ts",
    "smoke:installer:apply-rollback": "STACK_REPO_ROOT=\"$PWD\" bun run ../testing/stack/smoke/smoke_installer_apply_rollback.ts",
    "smoke:release-site:contract": "STACK_REPO_ROOT=\"$PWD\" bun run ../testing/stack/smoke/smoke_release_site_contract.ts",
    "smoke:artifact-security": "STACK_REPO_ROOT=\"$PWD\" bun run ../testing/stack/smoke/smoke_artifact_security.ts",
    "smoke:first-run:local": "STACK_REPO_ROOT=\"$PWD\" bun run ../testing/stack/smoke/smoke_first_run_local.ts",
    "smoke:launch-docs-alignment": "STACK_REPO_ROOT=\"$PWD\" bun run ../testing/stack/smoke/smoke_launch_docs_alignment.ts",
    "quality:static": "bun run check && bun run release-check",
    "quality:dev": "bun run quality:static && STACK_REPO_ROOT=\"$PWD\" bun run ../testing/stack/smoke/smoke_voice_tui.ts && STACK_REPO_ROOT=\"$PWD\" bun run ../testing/stack/smoke/smoke_gardener_v1.ts && STACK_REPO_ROOT=\"$PWD\" bun run ../testing/stack/smoke/smoke_guidance_l2.ts && STACK_REPO_ROOT=\"$PWD\" bun run ../testing/stack/smoke/smoke_monitor_style_steer.ts && bun run smoke:bombadil:b0",
    "quality:local": "STACK_REPO_ROOT=\"$PWD\" sh -c 'cd ../testing && make stack-ship-stable'",
    "quality:release": "bun run quality:local && bun run release-check:observability",
    "launch:readiness": "bun run scripts/launch_readiness.ts",
    "launch:nightly1": "bun run scripts/nightly1_packet.ts",
    "launch:nightly1:essentials": "bun run scripts/nightly1_essentials.ts",
    "launch:candidate": "bun run scripts/nightly_candidate.ts",
    "launch:cut-plan": "bun run scripts/nightly_cut_plan.ts",
    "release-check": "bun run scripts/release_check.ts",
    "release-check:observability": "STACK_RELEASE_CHECK_OBSERVABILITY=1 bun run scripts/release_check.ts",
    "observability:apply-retention": "bun run scripts/apply_observability_retention.ts",
    "stackeval:banking77-local-gepa": "STACK_REPO_ROOT=\"$PWD\" bun run ../evals/stackeval/wrappers/banking77_local_gepa.ts",
    "stackeval:banking77-local-gepa:prepare": "STACK_REPO_ROOT=\"$PWD\" bun run ../evals/stackeval/wrappers/banking77_local_gepa.ts --prepare-only",
    "stackeval:crafter-local-gepa": "STACK_REPO_ROOT=\"$PWD\" bun run ../evals/stackeval/wrappers/crafter_local_gepa.ts",
    "stackeval:crafter-local-gepa:prepare": "STACK_REPO_ROOT=\"$PWD\" bun run ../evals/stackeval/wrappers/crafter_local_gepa.ts --prepare-only",
    "stackeval:run": "STACK_REPO_ROOT=\"$PWD\" ../evals/stackeval/bin/stackeval run banking77-local-gepa",
    "stackeval:run:crafter": "STACK_REPO_ROOT=\"$PWD\" ../evals/stackeval/bin/stackeval run crafter-local-gepa",
    "stackeval:run:prepare": "STACK_REPO_ROOT=\"$PWD\" ../evals/stackeval/bin/stackeval prepare banking77-local-gepa",
    "stackeval:harness": "STACK_REPO_ROOT=\"$PWD\" ../evals/stackeval/bin/stackeval harness prepare banking77-local-gepa --preset smoke",
    "stackeval:tictactoe-harbor-env-rebuild": "STACK_REPO_ROOT=\"$PWD\" bun run ../evals/stackeval/wrappers/tictactoe_harbor_env_rebuild.ts",
    "stackeval:tictactoe-harbor-env-rebuild:prepare": "STACK_REPO_ROOT=\"$PWD\" bun run ../evals/stackeval/wrappers/tictactoe_harbor_env_rebuild.ts --prepare-only",
    "stackeval:tictactoe-harbor-env-rebuild:launch": "STACK_REPO_ROOT=\"$PWD\" bun run ../evals/stackeval/wrappers/tictactoe_harbor_env_rebuild.ts --launch-only",
    "stackeval:tictactoe-harbor-env-rebuild:verify": "STACK_REPO_ROOT=\"$PWD\" bun run ../evals/stackeval/wrappers/tictactoe_harbor_env_rebuild.ts --verify-only",
    "sync-version": "bun run scripts/sync_version.ts",
    "check-version-drift": "bun run scripts/check_version_drift.ts",
    "bump-dev": "bun run scripts/bump_dev.ts"
  },
  "dependencies": {
    "@opentui/core": "^0.4.1"
  },
  "devDependencies": {
    "@termless/core": "^0.7.0",
    "@termless/ghostty": "^0.4.0",
    "@termless/xtermjs": "^0.4.0",
    "@types/bun": "^1.3.6",
    "typescript": "^6.0.3"
  }
}
